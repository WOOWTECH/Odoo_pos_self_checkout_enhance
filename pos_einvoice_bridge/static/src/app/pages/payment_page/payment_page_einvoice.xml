<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Inject e-invoice carrier form into the self-order payment page -->
    <t t-inherit="pos_self_order_enhancement.PaymentPage" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-buttons-container')]" position="before">
            <div class="einvoice-settings bg-white rounded-3 shadow-sm p-3 mb-3"
                 t-if="showEinvoiceForm">
                <h6 class="fw-bold mb-3 text-muted">
                    <i class="fa fa-file-text-o me-2"></i>
                    Invoice / 電子發票
                </h6>

                <div class="d-flex flex-column gap-2 mb-2">
                    <label class="d-flex align-items-center gap-2">
                        <input type="radio" name="einv_carrier" value="print"
                               t-att-checked="invoiceState.carrierType === 'print'"
                               t-on-change="() => this.setCarrierType('print')"/>
                        <span>列印 Print</span>
                    </label>
                    <label class="d-flex align-items-center gap-2">
                        <input type="radio" name="einv_carrier" value="mobile"
                               t-att-checked="invoiceState.carrierType === 'mobile'"
                               t-on-change="() => this.setCarrierType('mobile')"/>
                        <span>手機條碼 Mobile Barcode</span>
                    </label>
                    <label class="d-flex align-items-center gap-2">
                        <input type="radio" name="einv_carrier" value="donation"
                               t-att-checked="invoiceState.carrierType === 'donation'"
                               t-on-change="() => this.setCarrierType('donation')"/>
                        <span>捐贈 Donation</span>
                    </label>
                    <label class="d-flex align-items-center gap-2">
                        <input type="radio" name="einv_carrier" value="b2b"
                               t-att-checked="invoiceState.carrierType === 'b2b'"
                               t-on-change="() => this.setCarrierType('b2b')"/>
                        <span>統編 B2B</span>
                    </label>
                </div>

                <!-- Mobile barcode input -->
                <div t-if="invoiceState.carrierType === 'mobile'" class="mt-2">
                    <input type="text" class="form-control"
                           placeholder="/XXXXXXX (手機條碼)"
                           t-att-value="invoiceState.carrierNum"
                           t-on-change="(ev) => this.invoiceState.carrierNum = ev.target.value"/>
                </div>

                <!-- Love code input -->
                <div t-if="invoiceState.carrierType === 'donation'" class="mt-2">
                    <input type="text" class="form-control"
                           placeholder="愛心碼 Love Code (e.g. 168001)"
                           t-att-value="invoiceState.loveCode"
                           t-on-change="(ev) => this.invoiceState.loveCode = ev.target.value"/>
                </div>

                <!-- B2B tax ID input -->
                <div t-if="invoiceState.carrierType === 'b2b'" class="mt-2">
                    <input type="text" class="form-control mb-2"
                           placeholder="統一編號 Tax ID (8 digits)"
                           t-att-value="invoiceState.buyerTaxId"
                           t-on-input="onTaxIdInput"
                           maxlength="8" inputmode="numeric"/>
                    <div t-if="invoiceState.lookingUp" class="text-muted small mb-1">
                        查詢中...
                    </div>
                    <input type="text" class="form-control"
                           placeholder="公司名稱 Company Name"
                           t-att-value="invoiceState.buyerName"
                           t-on-change="(ev) => this.invoiceState.buyerName = ev.target.value"/>
                </div>

                <!-- Validation error -->
                <div t-if="invoiceState.validationError" class="alert alert-danger mt-2 mb-0 py-2">
                    <small><t t-esc="invoiceState.validationError"/></small>
                </div>
            </div>
        </xpath>
    </t>

</templates>
