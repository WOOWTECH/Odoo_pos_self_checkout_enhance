<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_config_view_form_uber_direct" model="ir.ui.view">
        <field name="name">pos.config.form.uber.direct</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@groups='base.group_system']" position="before">
                <setting string="Uber Direct 外送"
                         help="Enable Uber Direct delivery for self-order takeaway customers / 啟用 Uber Direct 外送服務"
                         invisible="not module_pos_restaurant">
                    <div class="content-group">
                        <div class="row">
                            <div class="col-lg-5 o_light_label">
                                <label string="Enable Delivery / 啟用外送" for="uber_direct_enabled"/>
                            </div>
                            <div class="col-lg-7">
                                <field name="uber_direct_enabled"/>
                            </div>
                        </div>
                        <div invisible="not uber_direct_enabled">
                            <div class="row mt-2">
                                <div class="col-lg-5 o_light_label">
                                    <label string="Environment / 環境" for="uber_direct_env"/>
                                </div>
                                <div class="col-lg-7">
                                    <field name="uber_direct_env"/>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-lg-5 o_light_label">
                                    <label string="Client ID" for="uber_direct_client_id"/>
                                </div>
                                <div class="col-lg-7">
                                    <field name="uber_direct_client_id"/>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-lg-5 o_light_label">
                                    <label string="Client Secret" for="uber_direct_client_secret"/>
                                </div>
                                <div class="col-lg-7">
                                    <field name="uber_direct_client_secret" password="True"/>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-lg-5 o_light_label">
                                    <label string="Customer ID" for="uber_direct_customer_id"/>
                                </div>
                                <div class="col-lg-7">
                                    <field name="uber_direct_customer_id"/>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-lg-5 o_light_label">
                                    <label string="取餐地址" for="uber_direct_pickup_address"/>
                                </div>
                                <div class="col-lg-7">
                                    <field name="uber_direct_pickup_address"/>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-lg-5 o_light_label">
                                    <label string="取餐店名" for="uber_direct_pickup_name"/>
                                </div>
                                <div class="col-lg-7">
                                    <field name="uber_direct_pickup_name"/>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-lg-5 o_light_label">
                                    <label string="取餐電話" for="uber_direct_pickup_phone"/>
                                </div>
                                <div class="col-lg-7">
                                    <field name="uber_direct_pickup_phone"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
