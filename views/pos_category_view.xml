<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_category_form_kds_course" model="ir.ui.view">
        <field name="name">pos.category.form.kds.hold.fire</field>
        <field name="model">pos.category</field>
        <field name="inherit_id" ref="point_of_sale.product_pos_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sequence']" position="after">
                <group string="KDS Hold &amp; Fire">
                    <field name="kds_hold_fire"
                           help="Items in this category are held until staff fires them to the kitchen."/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
