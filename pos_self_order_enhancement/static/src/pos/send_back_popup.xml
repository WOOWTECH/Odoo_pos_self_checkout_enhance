<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_self_order_enhancement.SendBackPopup">
        <Dialog title="props.title or 'Send Back to Kitchen'" size="'md'">
            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="cancel">Cancel</button>
                <button class="btn btn-danger"
                        t-att-disabled="!hasSelection"
                        t-on-click="confirm">
                    Send Back
                </button>
            </t>
            <div class="send-back-popup">
                <div class="mb-3">
                    <label class="form-label fw-bold">Select items to send back:</label>
                    <t t-foreach="props.lines" t-as="line" t-key="line.id">
                        <div class="form-check py-1 border-bottom"
                             t-on-click="() => this.toggleLine(line.id)"
                             style="cursor: pointer;">
                            <input type="checkbox"
                                   class="form-check-input"
                                   t-att-checked="state.selectedLines[line.id]"
                                   readonly="1"/>
                            <label class="form-check-label w-100" style="cursor: pointer;">
                                <span class="fw-bold" t-esc="line.qty"/>x
                                <span t-esc="line.product_name"/>
                            </label>
                        </div>
                    </t>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Reason:</label>
                    <select class="form-select"
                            t-on-change="(ev) => this.state.reason = ev.target.value">
                        <t t-foreach="reasons" t-as="r" t-key="r.id">
                            <option t-att-value="r.id"
                                    t-att-selected="state.reason === r.id"
                                    t-esc="r.label"/>
                        </t>
                    </select>
                </div>
            </div>
        </Dialog>
    </t>
</templates>
