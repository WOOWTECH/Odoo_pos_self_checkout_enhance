<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Extend OrderSummary to show KDS status icons in the product-name slot -->
    <t t-name="pos_self_order_enhancement.OrderSummary" t-inherit="point_of_sale.OrderSummary" t-inherit-mode="extension">
        <xpath expr="//t[@t-set-slot='product-name']" position="inside">
            <span t-if="line.getKdsStatus() === 'done'" class="text-success ms-1" style="font-size: 0.85em;">✓</span>
            <span t-elif="line.getKdsStatus() === 'pending'" class="text-muted ms-1" style="font-size: 0.85em;">○</span>
        </xpath>
    </t>
</templates>
