<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Add E-Invoice settings to POS Configuration form -->
    <record id="pos_config_view_form_einvoice" model="ir.ui.view">
        <field name="name">pos.config.form.einvoice</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@groups='base.group_system']" position="before">
                <setting string="Taiwan E-Invoice (電子發票)"
                         help="Issue 統一發票 via ECPay at point of sale / 在銷售點透過綠界開立統一發票">
                    <div class="content-group">
                        <div class="row">
                            <div class="col-lg-5 o_light_label">
                                <label string="Enable E-Invoice / 啟用電子發票" for="ecpay_einvoice_enabled"/>
                            </div>
                            <div class="col-lg-7">
                                <field name="ecpay_einvoice_enabled"/>
                            </div>
                        </div>
                        <div invisible="not ecpay_einvoice_enabled" class="text-muted small mt-2">
                            ECPay credentials (MerchantID, HashKey, HashIV) are configured at the company level.
                            <br/>
                            綠界電子發票連線設定（特店編號、HashKey、HashIV）請至公司設定中設定。
                            <br/>
                            Path / 路徑: Settings &gt; Accounting &gt; ECPay 電子發票設定
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
