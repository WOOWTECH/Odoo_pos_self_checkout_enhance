<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_self_order_enhancement.ProductCard" t-inherit="pos_self_order.ProductCard" t-inherit-mode="extension">
        <!-- Grey out entire card when sold out -->
        <xpath expr="//article[hasclass('self_order_product_card')]" position="attributes">
            <attribute name="t-att-style">props.product.is_sold_out ? 'opacity: 0.4; pointer-events: none;' : ''</attribute>
        </xpath>
        <xpath expr="//div[hasclass('text-center')]/div[@t-if='!props.product.self_order_available']" position="before">
            <div t-if="props.product.is_sold_out" class="fs-lighter bg-danger text-white rounded p-1">售完</div>
        </xpath>
        <xpath expr="//div[hasclass('product-information-tag')]" position="replace"/>
    </t>
</templates>
