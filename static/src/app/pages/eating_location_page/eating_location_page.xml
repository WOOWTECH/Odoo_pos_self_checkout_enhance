<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Override location page: simplified welcome for both takeaway and dine-in URLs -->
    <t t-name="pos_self_order.EatingLocationPage" t-inherit="pos_self_order.EatingLocationPage" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_kiosk_eating_location')]" position="replace">
            <div class="o_kiosk_eating_location d-flex flex-column align-items-center flex-grow-1 bg-300 bg-gradient overflow-y-auto text-center">
                <!-- Takeaway URL (no table_identifier) -->
                <t t-if="isTakeawayUrl">
                    <h1 class="pt-3 m-0">外帶點餐</h1>
                    <div class="container d-flex flex-wrap align-items-center justify-content-center gap-3 my-auto">
                        <button t-on-click="enterTakeaway" role="button" class="o_kiosk_eating_location_box o_kiosk_eating_location_away btn btn-light">
                            <img src="/pos_self_order/static/img/takeAway.svg" />
                            <h3>外賣</h3>
                        </button>
                    </div>
                </t>
                <!-- Dine-in URL (has table_identifier) -->
                <t t-elif="isDineInUrl">
                    <h1 class="pt-3 m-0">內用點餐</h1>
                    <div class="container d-flex flex-wrap align-items-center justify-content-center gap-3 my-auto">
                        <button t-on-click="enterDineIn" role="button" class="o_kiosk_eating_location_box btn btn-light">
                            <img src="/pos_self_order/static/img/eatin.svg" />
                            <h3>堂食</h3>
                            <p t-if="tableInfo" class="text-muted mt-2 mb-0" t-esc="tableInfo"/>
                        </button>
                    </div>
                </t>
                <!-- Fallback: standard two-option layout -->
                <t t-else="">
                    <h1 class="pt-3 m-0">Choose your eating location</h1>
                    <div class="container d-flex flex-wrap align-items-center justify-content-center gap-3 my-auto">
                        <button t-on-click="() => this.selectLocation('in')" role="button" class="o_kiosk_eating_location_box btn btn-light">
                            <img src="/pos_self_order/static/img/eatin.svg" />
                            <h3>Eat In</h3>
                        </button>
                        <button t-on-click="() => this.selectLocation('out')" role="button" class="o_kiosk_eating_location_box o_kiosk_eating_location_away btn btn-light">
                            <img src="/pos_self_order/static/img/takeAway.svg" />
                            <h3>Take Out</h3>
                        </button>
                    </div>
                </t>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('page-buttons')]" position="replace">
            <div class="page-buttons shadow-sm p-3 bg-view border-top text-center">
                <t t-if="isTakeawayUrl">
                    <button class="btn btn-primary btn-lg px-5" t-on-click="enterTakeaway">
                        進入
                    </button>
                </t>
                <t t-elif="isDineInUrl">
                    <button class="btn btn-primary btn-lg px-5" t-on-click="enterDineIn">
                        進入
                    </button>
                </t>
                <t t-else="">
                    <button class="btn btn-secondary btn-lg" t-on-click="back">
                        <i class="oi oi-chevron-left"/>
                        Back
                    </button>
                </t>
            </div>
        </xpath>
    </t>
</templates>
