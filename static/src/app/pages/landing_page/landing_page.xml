<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Inherit and extend the LandingPage template -->
    <t t-inherit="pos_self_order.LandingPage" t-inherit-mode="extension">

        <!-- Override the "My Order/My Orders" button -->
        <xpath expr="//a[contains(@t-on-click, 'clickMyOrder')]" position="replace">
            <a
                type="button"
                t-on-click="clickMyOrderEnhanced"
                class="btn btn-lg btn-secondary"
                style="border-color: #714B67">
                <t t-if="draftOrder.length > 0">
                    My Order
                </t>
                <t t-else="">
                    Order History
                </t>
            </a>
        </xpath>

        <!-- Add "Continue Ordering" button after "My Order" button -->
        <xpath expr="//div[hasclass('o_pos_landing_footer')]//a[hasclass('btn-secondary')]" position="after">
            <a t-if="showContinueOrderingBtn" type="button" t-on-click="continueOrdering"
               class="btn btn-lg btn-secondary" style="border-color: #714B67">
                Continue Ordering
            </a>
        </xpath>

    </t>

</templates>
