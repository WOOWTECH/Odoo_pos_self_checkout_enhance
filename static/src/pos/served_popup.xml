<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_self_order_enhancement.ServedPopup">
        <Dialog title="dialogTitle" size="'md'">
            <div class="p-3">
                <h5 class="mb-3">
                    <i class="fa fa-check-circle text-success me-2"/>
                    <t t-esc="props.tableName"/>
                </h5>
                <div class="list-group mb-3">
                    <t t-foreach="props.items" t-as="item" t-key="item.id">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span>
                                <strong t-esc="item.qty"/>x
                                <t t-esc="item.name"/>
                            </span>
                        </div>
                    </t>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-secondary me-2" t-on-click="props.close">Close</button>
                <button class="btn btn-success btn-lg" t-on-click="onClickServed">
                    <i class="fa fa-check me-2"/>Mark as Served
                </button>
            </t>
        </Dialog>
    </t>
</templates>
